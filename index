<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Food Chemistry — Masters Revision Guide</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,500;0,700;1,400&family=JetBrains+Mono:wght@300;400;500&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #08111f;
    --surface: #0d1b2e;
    --card: #112240;
    --card2: #162d4a;
    --border: #1e3a5f;
    --accent: #e8a020;
    --accent2: #29c5d1;
    --accent3: #7fd18c;
    --text: #ccd6f6;
    --text-muted: #7a96b8;
    --text-bright: #e8f0fe;
    --red: #e05c6a;
    --purple: #a78bfa;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    overflow-x: hidden;
  }
  /* BG grid */
  body::before {
    content: '';
    position: fixed; inset: 0; z-index: 0;
    background-image:
      linear-gradient(rgba(41,197,209,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(41,197,209,0.04) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none;
  }

  /* ── HEADER ── */
  header {
    position: sticky; top: 0; z-index: 100;
    background: rgba(8,17,31,0.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    padding: 0 24px;
    display: flex; align-items: center; gap: 32px;
    height: 60px;
  }
  .logo {
    font-family: 'Playfair Display', serif;
    font-size: 1.1rem; font-weight: 700;
    color: var(--accent);
    white-space: nowrap;
    letter-spacing: 0.02em;
  }
  .logo span { color: var(--accent2); font-style: italic; }
  nav { display: flex; gap: 4px; flex: 1; justify-content: center; }
  .nav-btn {
    background: none; border: none; cursor: pointer;
    color: var(--text-muted); font-family: 'DM Sans', sans-serif;
    font-size: 0.82rem; font-weight: 500; letter-spacing: 0.08em;
    text-transform: uppercase; padding: 6px 16px; border-radius: 6px;
    transition: all 0.2s; white-space: nowrap;
  }
  .nav-btn:hover { color: var(--text-bright); background: var(--card); }
  .nav-btn.active { color: var(--accent); background: rgba(232,160,32,0.12); }
  .badge { 
    display: inline-block; background: var(--accent2); color: var(--bg);
    font-size: 0.62rem; font-weight: 700; padding: 1px 6px; border-radius: 10px;
    margin-left: 4px; vertical-align: middle;
  }

  /* ── MAIN LAYOUT ── */
  .page { display: none; position: relative; z-index: 1; }
  .page.active { display: block; }
  .container { max-width: 1280px; margin: 0 auto; padding: 28px 24px; }

  /* ── TOPICS PAGE ── */
  .topics-layout { display: grid; grid-template-columns: 220px 1fr; gap: 24px; align-items: start; }
  .topic-sidebar {
    position: sticky; top: 80px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 8px;
    overflow: hidden;
  }
  .sidebar-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.65rem; color: var(--text-muted);
    text-transform: uppercase; letter-spacing: 0.12em;
    padding: 8px 12px 6px;
  }
  .topic-btn {
    display: block; width: 100%;
    background: none; border: none; cursor: pointer;
    text-align: left; padding: 9px 12px; border-radius: 8px;
    color: var(--text-muted); font-family: 'DM Sans', sans-serif;
    font-size: 0.82rem; transition: all 0.15s;
    margin-bottom: 2px;
  }
  .topic-btn:hover { background: var(--card); color: var(--text); }
  .topic-btn.active { background: rgba(232,160,32,0.12); color: var(--accent); font-weight: 600; }
  .topic-num {
    display: inline-block; width: 20px; height: 20px; line-height: 20px;
    background: var(--card); border-radius: 4px;
    font-family: 'JetBrains Mono', monospace; font-size: 0.65rem;
    text-align: center; margin-right: 8px; color: var(--accent2);
  }
  .topic-btn.active .topic-num { background: rgba(232,160,32,0.2); color: var(--accent); }

  /* ── TOPIC CONTENT ── */
  .topic-content { display: none; animation: fadeIn 0.3s ease; }
  .topic-content.active { display: block; }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }

  .topic-header {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 28px 32px;
    margin-bottom: 20px;
    position: relative; overflow: hidden;
  }
  .topic-header::before {
    content: attr(data-emoji);
    position: absolute; right: 24px; top: 50%; transform: translateY(-50%);
    font-size: 5rem; opacity: 0.12;
  }
  .topic-tag {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.65rem; color: var(--accent2);
    text-transform: uppercase; letter-spacing: 0.14em;
    margin-bottom: 8px;
  }
  .topic-title {
    font-family: 'Playfair Display', serif;
    font-size: 2rem; font-weight: 700; color: var(--text-bright);
    line-height: 1.2;
  }
  .topic-subtitle { color: var(--text-muted); font-size: 0.9rem; margin-top: 8px; font-style: italic; }

  .cards-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 16px; margin-bottom: 20px; }
  .card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 12px; padding: 20px;
    transition: border-color 0.2s;
  }
  .card:hover { border-color: var(--accent2); }
  .card-title {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.1em;
    color: var(--accent); margin-bottom: 12px;
    display: flex; align-items: center; gap: 8px;
  }
  .card-title::before { content: '▸'; color: var(--accent2); }
  .card p { font-size: 0.87rem; line-height: 1.7; color: var(--text); }
  .card ul { list-style: none; padding: 0; }
  .card ul li { font-size: 0.87rem; line-height: 1.7; color: var(--text); padding-left: 16px; position: relative; }
  .card ul li::before { content: '·'; position: absolute; left: 4px; color: var(--accent2); }

  .equation-box {
    background: var(--bg); border: 1px solid var(--border);
    border-left: 3px solid var(--accent2);
    border-radius: 8px; padding: 16px 20px; margin: 12px 0;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.9rem; color: var(--accent2);
    line-height: 1.8;
  }
  .eq-label { font-size: 0.68rem; color: var(--text-muted); margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.1em; }
  .eq-vars { font-size: 0.78rem; color: var(--text-muted); margin-top: 8px; font-family: 'DM Sans', sans-serif; }

  .highlight-box {
    background: rgba(232,160,32,0.06);
    border: 1px solid rgba(232,160,32,0.2);
    border-radius: 10px; padding: 16px 20px; margin: 16px 0;
  }
  .highlight-box .hl-title { color: var(--accent); font-weight: 600; font-size: 0.85rem; margin-bottom: 8px; }
  .highlight-box p, .highlight-box li { font-size: 0.87rem; line-height: 1.7; }

  table { width: 100%; border-collapse: collapse; font-size: 0.85rem; margin: 12px 0; }
  th { background: var(--card2); color: var(--accent); padding: 10px 14px; text-align: left; font-family: 'JetBrains Mono', monospace; font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.08em; border-bottom: 1px solid var(--border); }
  td { padding: 9px 14px; border-bottom: 1px solid rgba(30,58,95,0.5); color: var(--text); }
  tr:last-child td { border-bottom: none; }
  tr:hover td { background: rgba(255,255,255,0.02); }

  .ref-box {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 10px; padding: 16px 20px; margin-top: 20px;
  }
  .ref-title { font-family: 'JetBrains Mono', monospace; font-size: 0.68rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 10px; }
  .ref-item { font-size: 0.8rem; color: var(--text-muted); margin-bottom: 6px; padding-left: 16px; position: relative; }
  .ref-item::before { content: '[' attr(data-n) ']'; position: absolute; left: -4px; color: var(--accent2); font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; }

  /* ── QUIZ PAGE ── */
  .quiz-wrap { max-width: 780px; margin: 0 auto; }
  .quiz-intro {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 16px; padding: 28px 32px; margin-bottom: 24px;
    text-align: center;
  }
  .quiz-intro h2 { font-family: 'Playfair Display', serif; font-size: 1.8rem; color: var(--text-bright); margin-bottom: 8px; }
  .quiz-intro p { color: var(--text-muted); font-size: 0.9rem; }

  .q-card {
    background: var(--card); border: 1px solid var(--border);
    border-radius: 14px; padding: 24px 28px; margin-bottom: 16px;
    transition: border-color 0.2s;
  }
  .q-number { font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; color: var(--accent2); letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 10px; }
  .q-text { font-size: 1rem; color: var(--text-bright); line-height: 1.6; margin-bottom: 18px; font-weight: 500; }
  .options { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
  .opt {
    background: var(--surface); border: 1.5px solid var(--border);
    border-radius: 8px; padding: 12px 16px; cursor: pointer;
    font-size: 0.87rem; color: var(--text); transition: all 0.15s;
    text-align: left; font-family: 'DM Sans', sans-serif;
  }
  .opt:hover:not(:disabled) { border-color: var(--accent2); color: var(--text-bright); }
  .opt.correct { border-color: var(--accent3)!important; background: rgba(127,209,140,0.1)!important; color: var(--accent3)!important; }
  .opt.wrong { border-color: var(--red)!important; background: rgba(224,92,106,0.1)!important; color: var(--red)!important; }
  .opt:disabled { cursor: default; }

  .explanation {
    display: none; margin-top: 14px;
    background: rgba(41,197,209,0.06);
    border: 1px solid rgba(41,197,209,0.2);
    border-radius: 8px; padding: 12px 16px;
    font-size: 0.85rem; color: var(--text); line-height: 1.6;
  }
  .explanation.show { display: block; animation: fadeIn 0.3s ease; }
  .explanation strong { color: var(--accent2); }

  .quiz-actions { text-align: center; margin-top: 24px; }
  .btn-primary {
    background: var(--accent); color: var(--bg);
    border: none; padding: 12px 32px; border-radius: 8px;
    font-family: 'DM Sans', sans-serif; font-size: 0.9rem; font-weight: 700;
    cursor: pointer; transition: all 0.2s; letter-spacing: 0.05em;
  }
  .btn-primary:hover { background: #f0b030; transform: translateY(-1px); box-shadow: 0 6px 20px rgba(232,160,32,0.3); }
  .btn-secondary {
    background: var(--card); color: var(--text);
    border: 1px solid var(--border); padding: 12px 32px; border-radius: 8px;
    font-family: 'DM Sans', sans-serif; font-size: 0.9rem;
    cursor: pointer; transition: all 0.2s; margin-left: 12px;
  }
  .btn-secondary:hover { border-color: var(--accent2); color: var(--text-bright); }

  .score-display {
    display: none; text-align: center;
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 16px; padding: 36px;
  }
  .score-display.show { display: block; animation: fadeIn 0.4s ease; }
  .score-circle {
    width: 120px; height: 120px; border-radius: 50%;
    border: 4px solid var(--accent); margin: 0 auto 16px;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
  }
  .score-num { font-family: 'Playfair Display', serif; font-size: 2.4rem; color: var(--accent); font-weight: 700; line-height: 1; }
  .score-den { font-size: 0.85rem; color: var(--text-muted); }
  .score-msg { font-family: 'Playfair Display', serif; font-size: 1.4rem; color: var(--text-bright); margin-bottom: 8px; }
  .score-sub { color: var(--text-muted); font-size: 0.88rem; }

  /* ── CHATBOT ── */
  .chat-layout { max-width: 820px; margin: 0 auto; }
  .chat-header {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 14px 14px 0 0; padding: 20px 24px;
    display: flex; align-items: center; gap: 14px;
  }
  .chat-avatar {
    width: 44px; height: 44px; border-radius: 50%;
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    display: flex; align-items: center; justify-content: center;
    font-size: 1.3rem; flex-shrink: 0;
  }
  .chat-name { font-weight: 600; color: var(--text-bright); font-size: 0.95rem; }
  .chat-status { font-size: 0.78rem; color: var(--accent3); }

  .chat-messages {
    background: var(--card);
    border-left: 1px solid var(--border); border-right: 1px solid var(--border);
    height: 460px; overflow-y: auto; padding: 20px;
    display: flex; flex-direction: column; gap: 16px;
    scroll-behavior: smooth;
  }
  .chat-messages::-webkit-scrollbar { width: 4px; }
  .chat-messages::-webkit-scrollbar-track { background: transparent; }
  .chat-messages::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

  .msg { display: flex; gap: 12px; animation: fadeIn 0.3s ease; max-width: 90%; }
  .msg.user { flex-direction: row-reverse; align-self: flex-end; }
  .msg-avatar {
    width: 32px; height: 32px; border-radius: 50%; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    font-size: 0.9rem;
  }
  .msg.ai .msg-avatar { background: linear-gradient(135deg, var(--accent), var(--accent2)); }
  .msg.user .msg-avatar { background: var(--card2); }
  .msg-bubble {
    padding: 12px 16px; border-radius: 12px;
    font-size: 0.88rem; line-height: 1.6;
  }
  .msg.ai .msg-bubble { background: var(--surface); color: var(--text); border-radius: 4px 12px 12px 12px; border: 1px solid var(--border); }
  .msg.user .msg-bubble { background: rgba(232,160,32,0.12); color: var(--text-bright); border-radius: 12px 4px 12px 12px; border: 1px solid rgba(232,160,32,0.25); }

  .suggested-qs { padding: 12px 20px; background: var(--surface); border-left: 1px solid var(--border); border-right: 1px solid var(--border); display: flex; gap: 8px; flex-wrap: wrap; }
  .sug-btn { background: var(--card); border: 1px solid var(--border); border-radius: 20px; padding: 5px 14px; font-size: 0.78rem; color: var(--text-muted); cursor: pointer; transition: all 0.15s; font-family: 'DM Sans', sans-serif; }
  .sug-btn:hover { border-color: var(--accent2); color: var(--accent2); }

  .chat-input-area {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 0 0 14px 14px; padding: 16px 20px;
    display: flex; gap: 10px;
  }
  .chat-input {
    flex: 1; background: var(--card); border: 1px solid var(--border);
    border-radius: 8px; padding: 10px 16px; color: var(--text);
    font-family: 'DM Sans', sans-serif; font-size: 0.88rem;
    outline: none; resize: none; min-height: 44px; max-height: 120px;
  }
  .chat-input:focus { border-color: var(--accent2); }
  .chat-input::placeholder { color: var(--text-muted); }
  .send-btn {
    background: var(--accent); color: var(--bg);
    border: none; border-radius: 8px; padding: 10px 18px;
    cursor: pointer; font-size: 1rem; transition: all 0.2s;
    display: flex; align-items: center;
  }
  .send-btn:hover { background: #f0b030; }
  .send-btn:disabled { opacity: 0.5; cursor: default; }

  .typing { display: flex; gap: 4px; align-items: center; padding: 4px 0; }
  .typing span { width: 7px; height: 7px; border-radius: 50%; background: var(--text-muted); animation: bounce 1.4s infinite; }
  .typing span:nth-child(2) { animation-delay: 0.2s; }
  .typing span:nth-child(3) { animation-delay: 0.4s; }
  @keyframes bounce { 0%,80%,100% { transform: scale(0.6); opacity: 0.4; } 40% { transform: scale(1); opacity: 1; } }

  /* ── FLASHCARDS ── */
  .flashcard-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 16px; }
  .fc {
    background: var(--card); border: 1px solid var(--border);
    border-radius: 12px; padding: 22px;
    cursor: pointer; transition: all 0.2s;
    min-height: 160px; display: flex; flex-direction: column;
    position: relative; overflow: hidden;
  }
  .fc:hover { border-color: var(--accent2); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.3); }
  .fc-topic { font-family: 'JetBrains Mono', monospace; font-size: 0.65rem; color: var(--accent2); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 12px; }
  .fc-q { font-size: 0.92rem; color: var(--text-bright); font-weight: 500; line-height: 1.5; flex: 1; }
  .fc-a {
    display: none; font-size: 0.87rem; color: var(--accent3);
    line-height: 1.6; border-top: 1px solid var(--border); margin-top: 12px; padding-top: 12px;
  }
  .fc.flipped .fc-q { display: none; }
  .fc.flipped .fc-a { display: block; }
  .fc-hint { font-size: 0.72rem; color: var(--text-muted); margin-top: 10px; }
  .fc-filter { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 20px; }
  .fc-filter-btn { background: var(--card); border: 1px solid var(--border); border-radius: 6px; padding: 6px 14px; font-size: 0.8rem; color: var(--text-muted); cursor: pointer; transition: all 0.15s; font-family: 'DM Sans', sans-serif; }
  .fc-filter-btn:hover, .fc-filter-btn.active { background: rgba(41,197,209,0.1); border-color: var(--accent2); color: var(--accent2); }

  /* ── OVERVIEW HOME ── */
  .overview-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 16px; }
  .ov-card {
    background: var(--card); border: 1px solid var(--border);
    border-radius: 14px; padding: 22px; cursor: pointer;
    transition: all 0.2s; text-decoration: none;
  }
  .ov-card:hover { border-color: var(--accent); transform: translateY(-2px); box-shadow: 0 10px 30px rgba(0,0,0,0.3); }
  .ov-icon { font-size: 2rem; margin-bottom: 12px; }
  .ov-name { font-weight: 600; color: var(--text-bright); font-size: 0.95rem; margin-bottom: 6px; }
  .ov-desc { font-size: 0.8rem; color: var(--text-muted); line-height: 1.5; }
  .page-hero { text-align: center; padding: 40px 24px 32px; }
  .page-hero h1 { font-family: 'Playfair Display', serif; font-size: 2.6rem; color: var(--text-bright); margin-bottom: 10px; }
  .page-hero h1 em { color: var(--accent); font-style: normal; }
  .page-hero p { color: var(--text-muted); font-size: 1rem; max-width: 560px; margin: 0 auto; }
  .stat-row { display: flex; justify-content: center; gap: 32px; margin-top: 24px; flex-wrap: wrap; }
  .stat { text-align: center; }
  .stat-num { font-family: 'Playfair Display', serif; font-size: 2rem; color: var(--accent); font-weight: 700; }
  .stat-label { font-size: 0.75rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.1em; }

  .section-label {
    font-family: 'JetBrains Mono', monospace; font-size: 0.68rem;
    color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.12em;
    margin-bottom: 16px; padding-bottom: 8px; border-bottom: 1px solid var(--border);
  }

  .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  @media(max-width: 600px) { .two-col, .options { grid-template-columns: 1fr; } .topics-layout { grid-template-columns: 1fr; } .topic-sidebar { position: static; } }

  .progress-bar-wrap { background: var(--card); border-radius: 4px; height: 6px; margin-top: 16px; overflow: hidden; }
  .progress-bar { height: 100%; background: linear-gradient(90deg, var(--accent2), var(--accent)); border-radius: 4px; transition: width 0.5s ease; }

  /* text formatting inside cards */
  b { color: var(--accent); font-weight: 600; }
  .accent2 { color: var(--accent2); }
  .green { color: var(--accent3); }

  hr.divider { border: none; border-top: 1px solid var(--border); margin: 20px 0; }

  .tag {
    display: inline-block; font-size: 0.72rem; padding: 2px 10px;
    border-radius: 12px; margin: 2px;
    font-family: 'JetBrains Mono', monospace;
  }
  .tag-blue { background: rgba(41,197,209,0.12); color: var(--accent2); border: 1px solid rgba(41,197,209,0.25); }
  .tag-amber { background: rgba(232,160,32,0.1); color: var(--accent); border: 1px solid rgba(232,160,32,0.25); }
  .tag-green { background: rgba(127,209,140,0.1); color: var(--accent3); border: 1px solid rgba(127,209,140,0.25); }

  /* overflow table wrapper */
  .table-wrap { overflow-x: auto; border-radius: 8px; border: 1px solid var(--border); }
</style>
</head>
<body>

<header>
  <div class="logo">Food<span>Chem</span> ⬡</div>
  <nav>
    <button class="nav-btn active" onclick="showPage('home')">Overview</button>
    <button class="nav-btn" onclick="showPage('topics')">Topics <span class="badge">10</span></button>
    <button class="nav-btn" onclick="showPage('quiz')">Quiz <span class="badge">10Q</span></button>
    <button class="nav-btn" onclick="showPage('flash')">Flashcards</button>
    <button class="nav-btn" onclick="showPage('chat')">AI Tutor 🤖</button>
  </nav>
</header>

<!-- ═══════════ HOME ═══════════ -->
<div id="page-home" class="page active">
