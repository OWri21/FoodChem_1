let answered = new Array(10).fill(null);

function buildQuiz() {
  const container = document.getElementById('quiz-questions');
  container.innerHTML = quizData.map((q, i) => `
    <div class="q-card" id="qcard-${i}">
      <div class="q-number">Question ${i+1} / 10 · ${q.topic}</div>
      <div class="q-text">${q.q}</div>
      <div class="options">
        ${q.opts.map((o, j) => `
          <button class="opt" data-q="${i}" data-opt="${j}" onclick="selectOpt(${i},${j})">${String.fromCharCode(65+j)}. ${o}</button>
        `).join('')}
      </div>
      <div class="explanation" id="exp-${i}">${q.exp}</div>
    </div>
  `).join('');
}

function selectOpt(qi, oi) {
  if (answered[qi] !== null) return;
  answered[qi] = oi;
  const qcard = document.getElementById('qcard-' + qi);
  qcard.querySelectorAll('.opt').forEach(btn => {
    btn.disabled = true;
    const idx = parseInt(btn.dataset.opt);
    if (idx === quizData[qi].ans) btn.classList.add('correct');
    else if (idx === oi) btn.classList.add('wrong');
  });
  document.getElementById('exp-' + qi).classList.add('show');
  updateProgress();
}

function updateProgress() {
  const done = answered.filter(a => a !== null).length;
  document.getElementById('quiz-progress').style.width = (done / 10 * 100) + '%';
  document.getElementById('quiz-progress-text').textContent = `${done} / 10 answered`;
}

function showScore() {
  const score = answered.filter((a, i) => a === quizData[i].ans).length;
  const sd = document.getElementById('score-display');
  sd.classList.add('show');
  document.getElementById('score-num').textContent = score;
  const msgs = ['Keep Revising', 'Good Start', 'Solid Progress', 'Well Done!', 'Excellent!'];
  const subs = ['Review all topics carefully', 'Focus on the topics you missed', 'You are getting there!', 'Strong understanding!', 'Outstanding performance!'];
  const tier = Math.floor(score / 2.5);
  document.getElementById('score-msg').textContent = msgs[Math.min(tier, 4)];
  document.getElementById('score-sub').textContent = subs[Math.min(tier, 4)];
  const c = score >= 8 ? '#7fd18c' : score >= 5 ? '#e8a020' : '#e05c6a';
  document.getElementById('score-circle').style.borderColor = c;
  document.getElementById('score-num').style.color = c;
  sd.scrollIntoView({behavior:'smooth'});
}

function resetQuiz() {
  answered = new Array(10).fill(null);
  buildQuiz();
  document.getElementById('score-display').classList.remove('show');
  updateProgress();
}

buildQuiz();

